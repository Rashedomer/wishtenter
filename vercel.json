{
  "framework": "vite",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(favicon.ico|favicon.svg|favicon-16.png|favicon-32.png|wishtenter-icon.png|logo.jpeg|pwa-icon-.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "/wishtenter-icon.png",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/media/:path*",
      "destination": "https://wishtenter-system-production.up.railway.app/api/media/:path*"
    },
    {
      "source": "/((?!api/|assets/|uploads/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
