{
  "framework": "vite",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/media/:path*",
      "destination": "https://wishtenter-system-production.up.railway.app/api/media/:path*"
    },
    {
      "source": "/((?!api/|assets/|uploads/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
